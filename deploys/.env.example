# =========================================
# Docker Registry Configuration
# =========================================
DOCKER_USERNAME=yourusername
VERSION=latest

# =========================================
# NATS Server Configuration
# =========================================
NATS_URL=nats://localhost:4222

# =========================================
# Database URLs
# =========================================
DATABASE_URL_USER=postgresql://postgres:your_secure_password@db-server:5432/user_db
DATABASE_URL_PRODUCT=postgresql://postgres:your_secure_password@db-server:5432/product_db
DATABASE_URL_ORDER=postgresql://postgres:your_secure_password@db-server:5432/order_db
DATABASE_URL_CART=postgresql://postgres:your_secure_password@db-server:5432/cart_db
DATABASE_URL_PAYMENT=postgresql://postgres:your_secure_password@db-server:5432/payment_db
DATABASE_URL_REPORT=postgresql://postgres:your_secure_password@db-server:5432/report_db
DATABASE_URL_AR=postgresql://postgres:your_secure_password@db-server:5432/ar_db

# =========================================
# Gateway Configuration
# =========================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3000,https://yourdomain.com

# =========================================
# Logging and Environment
# =========================================
LOG_LEVEL=debug
NODE_ENV=production
