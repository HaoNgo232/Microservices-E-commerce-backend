### Order Management Tests
### Test order creation and status updates

@token = {{loginCustomer.response.body.accessToken}}
@adminToken = {{loginAdmin.response.body.accessToken}}
@addressId = {{createAddress.response.body.id}}
@productId = {{createProduct.response.body.id}}

### 1. Create Order from Cart
# @name createOrder
POST {{gatewayUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "addressId": "{{addressId}}",
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 2,
      "priceInt": 2999000000
    }
  ]
}

### 2. Get Order Details
GET {{gatewayUrl}}/orders/{{createOrder.response.body.id}}
Authorization: Bearer {{token}}

### 3. List User's Orders
GET {{gatewayUrl}}/orders?page=1&pageSize=10
Authorization: Bearer {{token}}

### 4. Update Order Status (Admin only)
PUT {{gatewayUrl}}/orders/{{createOrder.response.body.id}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "PAID"
}

### 5. Update to SHIPPED
PUT {{gatewayUrl}}/orders/{{createOrder.response.body.id}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "SHIPPED"
}

### 6. Cancel Order (Customer)
PUT {{gatewayUrl}}/orders/{{createOrder.response.body.id}}/cancel
Authorization: Bearer {{token}}

### 7. Try to cancel already shipped order (expect error)
PUT {{gatewayUrl}}/orders/{{createOrder.response.body.id}}/cancel
Authorization: Bearer {{token}}

### 8. Create Order without address
POST {{gatewayUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "items": [
    {
      "productId": "{{productId}}",
      "quantity": 1,
      "priceInt": 2999000000
    }
  ]
}