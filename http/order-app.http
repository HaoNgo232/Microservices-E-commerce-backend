### ==========================================
### order-app.http
### Test Orders qua API Gateway
### - POST /orders: Gateway tự gắn userId từ JWT
### ==========================================

# Base variables (fallback nếu chưa chọn environment trong http-client.env.json)
@hostname = localhost
@port = 3000
@gateway = http://{{hostname}}:{{port}}

### Tạo user đăng nhập
@orderEmail = order-{{$timestamp}}@example.com
@orderPassword = Test@123456

### 0) REGISTER
POST {{gateway}}/auth/register
Content-Type: application/json

{
  "email": "{{orderEmail}}",
  "password": "{{orderPassword}}",
  "fullName": "Order Tester"
}

###

### 1) LOGIN
### @name loginOrderUser
POST {{gateway}}/auth/login
Content-Type: application/json

{
  "email": "{{orderEmail}}",
  "password": "{{orderPassword}}"
}

###

@orderToken = {{loginOrderUser.response.body.accessToken}}

### 2) CREATE ADDRESS (để gắn vào order)
### @name createOrderAddress
POST {{gateway}}/addresses
Authorization: Bearer {{orderToken}}
Content-Type: application/json

{
  "fullName": "Người Nhận",
  "phone": "0911111111",
  "street": "10 Phố Huế",
  "ward": "Hàng Bài",
  "district": "Hoàn Kiếm",
  "city": "Hà Nội",
  "isDefault": true
}

###

@orderAddressId = {{createOrderAddress.response.body.id}}

### 3) CREATE PRODUCT (lấy productId & priceInt)
@skuOrder = SKU-ORDER-{{$timestamp}}
@slugOrder = product-order-{{$timestamp}}

# @name createOrderProduct
POST {{gateway}}/products
Authorization: Bearer {{orderToken}}
Content-Type: application/json

{
  "sku": "{{skuOrder}}",
  "name": "Order Test Product",
  "slug": "{{slugOrder}}",
  "priceInt": 259900,
  "stock": 50,
  "imageUrls": ["https://example.com/order.jpg"]
}

###

@orderProductId = {{createOrderProduct.response.body.id}}
@orderPriceInt = {{createOrderProduct.response.body.priceInt}}

### 4) ORDERS - Create
### @name createOrder
POST {{gateway}}/orders
Authorization: Bearer {{orderToken}}
Content-Type: application/json

{
  "addressId": "{{orderAddressId}}",
  "items": [
    {
      "productId": "{{orderProductId}}",
      "quantity": 2,
      "priceInt": {{orderPriceInt}}
    }
  ]
}

###

@orderId = {{createOrder.response.body.id}}

### 5) ORDERS - Get by ID
GET {{gateway}}/orders/{{orderId}}
Authorization: Bearer {{orderToken}}

###

### 6) ORDERS - List by current user
GET {{gateway}}/orders?page=1&pageSize=10
Authorization: Bearer {{orderToken}}

###

### 7) ORDERS - Update status (PAID)
PUT {{gateway}}/orders/{{orderId}}/status
Authorization: Bearer {{orderToken}}
Content-Type: application/json

{
  "status": "PAID"
}

###

### 8) ORDERS - Cancel (có thể thử sau khi PAID, service cho phép PENDING/PAID -> CANCELLED)
PUT {{gateway}}/orders/{{orderId}}/cancel
Authorization: Bearer {{orderToken}}

###