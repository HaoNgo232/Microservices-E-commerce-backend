### ==========================================
### COMPREHENSIVE ENDPOINT TEST
### Test tất cả endpoints của hệ thống
### ==========================================

@gatewayUrl = http://localhost:3000

### ==========================================
### STEP 1: HEALTH CHECK
### ==========================================

### Health Check
# @name healthCheck
GET {{gatewayUrl}}/health

###

### ==========================================
### STEP 2: AUTHENTICATION
### ==========================================

### Register Admin
# @name registerAdmin
POST {{gatewayUrl}}/auth/register
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "Admin@123456",
  "fullName": "Admin User"
}

###

### Register Customer
# @name registerCustomer
POST {{gatewayUrl}}/auth/register
Content-Type: application/json

{
  "email": "customer@test.com",
  "password": "Customer@123456",
  "fullName": "Customer User"
}

###

### Login Admin
# @name loginAdmin
POST {{gatewayUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "Admin@123456"
}

###

### Login Customer
# @name loginCustomer
POST {{gatewayUrl}}/auth/login
Content-Type: application/json

{
  "email": "customer@test.com",
  "password": "Customer@123456"
}

###

@adminToken = {{loginAdmin.response.body.accessToken}}
@customerToken = {{loginCustomer.response.body.accessToken}}
###
@adminId = {{loginAdmin.response.body.user.id}}
@customerId = {{loginCustomer.response.body.user.id}}

### ==========================================
### STEP 3: USER ENDPOINTS
### ==========================================

### 3.1. List Users (Admin only) ✅
GET {{gatewayUrl}}/users?page=1&pageSize=10
Authorization: Bearer {{adminToken}}

###

### 3.2. Get User by ID ✅
GET {{gatewayUrl}}/users/{{adminId}}
Authorization: Bearer {{adminToken}}

###

### 3.3. Get User by Email (Admin only) ✅
GET {{gatewayUrl}}/users/email/customer@test.com
Authorization: Bearer {{adminToken}}

###

### 3.4. Update User ✅
PUT {{gatewayUrl}}/users/{{customerId}}
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "fullName": "Customer Updated",
  "phone": "0912345678"
}

###

### 3.5. Test Authorization - Customer tries to access admin-only endpoint ❌ (Expected: 403)
GET {{gatewayUrl}}/users
Authorization: Bearer {{customerToken}}

###

### ==========================================
### STEP 4: ADDRESS ENDPOINTS
### ==========================================

### 4.1. List Addresses ✅
GET {{gatewayUrl}}/addresses
Authorization: Bearer {{customerToken}}

###

### 4.2. Create Address ✅ (Fixed: userId from JWT)
# @name createAddress
POST {{gatewayUrl}}/addresses
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "fullName": "Nguyễn Văn A",
  "phone": "0912345678",
  "street": "123 Lê Lợi",
  "ward": "Phường Bến Nghé",
  "district": "Quận 1",
  "city": "TP. Hồ Chí Minh",
  "isDefault": true
}

###

@addressId = {{createAddress.response.body.id}}

### 4.3. Update Address ✅
PUT {{gatewayUrl}}/addresses/{{addressId}}
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "fullName": "Nguyễn Văn A - Updated",
  "phone": "0987654321",
  "street": "789 Updated Street"
}

###

### 4.4. Set Default Address ✅
PUT {{gatewayUrl}}/addresses/{{addressId}}/set-default
Authorization: Bearer {{customerToken}}

###

### 4.5. Delete Address (will skip) ⏭️
# DELETE {{gatewayUrl}}/addresses/{{addressId}}
# Authorization: Bearer {{customerToken}}

###

### ==========================================
### STEP 5: CATEGORY ENDPOINTS
### ==========================================

### 5.1. Create Category ✅
# @name createCategory
POST {{gatewayUrl}}/categories
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Electronics",
  "description": "Electronic products",
  "slug": "electronics",
  "parentId": null
}

###

@categoryId = {{createCategory.response.body.id}}

### 5.2. List Categories ✅
GET {{gatewayUrl}}/categories

###

### 5.3. Get Category by ID ✅
GET {{gatewayUrl}}/categories/{{categoryId}}

###

### 5.4. Update Category ✅
PUT {{gatewayUrl}}/categories/{{categoryId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Electronics Updated",
  "description": "Updated description"
}

###

### ==========================================
### STEP 6: PRODUCT ENDPOINTS
### ==========================================

### 6.1. Create Product ✅
# @name createProduct
POST {{gatewayUrl}}/products
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Test Product",
  "description": "Test description",
  "price": 100000,
  "stock": 100,
  "sku": "TEST-SKU-001",
  "categoryId": "{{categoryId}}"
}

###

@productId = {{createProduct.response.body.id}}

### 6.2. List Products ✅
GET {{gatewayUrl}}/products?page=1&pageSize=10

###

### 6.3. Get Product by ID ✅
GET {{gatewayUrl}}/products/{{productId}}

###

### 6.4. Update Product ✅
PUT {{gatewayUrl}}/products/{{productId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Test Product Updated",
  "price": 150000
}

###

### ==========================================
### STEP 7: CART ENDPOINTS
### ==========================================

### 7.1. Add to Cart ✅
POST {{gatewayUrl}}/cart/items
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "productId": "{{productId}}",
  "quantity": 2
}

###

### 7.2. Get Cart ✅
GET {{gatewayUrl}}/cart
Authorization: Bearer {{customerToken}}

###

### 7.3. Update Cart Item ✅
PUT {{gatewayUrl}}/cart/items/{{productId}}
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "quantity": 5
}

###

### 7.4. Remove from Cart ✅
DELETE {{gatewayUrl}}/cart/items/{{productId}}
Authorization: Bearer {{customerToken}}

###

### 7.5. Clear Cart ✅
DELETE {{gatewayUrl}}/cart
Authorization: Bearer {{customerToken}}

###

