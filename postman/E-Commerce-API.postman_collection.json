  "item": [
    {
      "name": "🔧 Setup (Run First)",
      "description": "Chạy theo thứ tự để khởi tạo user, token, và dữ liệu cần thiết",
      "item": [
        {
          "name": "1. Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{gateway}}/auth/register",
              "protocol": "{{gateway}}/auth/register",
              "path": []
            },
            "description": "Base variables (fallback nếu chưa chọn environment trong http-client.env.json)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"fullName\": \"HTTP Test User\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "2. Login & Get Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{gateway}}/auth/login",
              "protocol": "{{gateway}}/auth/login",
              "path": []
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set(\"token\", response.accessToken);",
                  "    console.log(\"✅ Token saved:\", response.accessToken.substring(0, 20) + \"...\");",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Get User Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{gateway}}/auth/me",
              "protocol": "{{gateway}}/auth/me",
              "path": []
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set(\"userId\", response.id);",
                  "    console.log(\"✅ User ID saved:\", response.id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
