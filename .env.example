
# NATS Message Broker

NATS_URL=nats://localhost:4222


# Gateway Configuration

PORT=3000

# CORS Configuration (comma-separated origins)
# Development: Use * or specific localhost ports
# Production: MUST specify exact frontend domains
CORS_ORIGIN=*


# JWT Authentication

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database URLs (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Development: Match docker-compose.yml ports
# Production: Use managed database services with SSL

DATABASE_URL_USER=postgresql://user:user_password@localhost:5433/user_db?schema=public
DATABASE_URL_PRODUCT=postgresql://product:product_password@localhost:5434/product_db?schema=public
DATABASE_URL_CART=postgresql://cart:cart_password@localhost:5435/cart_db?schema=public
DATABASE_URL_ORDER=postgresql://order:order_password@localhost:5436/order_db?schema=public
DATABASE_URL_PAYMENT=postgresql://payment:payment_password@localhost:5437/payment_db?schema=public
DATABASE_URL_AR=postgresql://ar:ar_password@localhost:5438/ar_db?schema=public
DATABASE_URL_REPORT=postgresql://report:report_password@localhost:5439/report_db?schema=public


# Application Environment

NODE_ENV=development

LOG_LEVEL=info


# Payment Config - SePay Integration
# LƯU Ý QUAN TRỌNG CHO BIDV:
# 1. BIDV KHÔNG thể đồng bộ giao dịch qua tài khoản chính
# 2. PHẢI dùng số tài khoản ảo (VA - Virtual Account)
# 3. Đăng ký VA tại https://my.sepay.vn
# 4. ACCOUNT_NAME là BẮT BUỘC - webhook sẽ KHÔNG hoạt động nếu thiếu

# Số tài khoản ảo (VA) - KHÔNG phải số tài khoản chính
# Format: {SốChính}{MãVA} - VD: 96247HAOVA
# Đăng ký VA tại: https://my.sepay.vn
SEPAY_ACCOUNT_NUMBER=96247HAOVA

# Tên ngân hàng chuẩn SePay
# VD: BIDV, MBBank, Vietcombank, ACB, VPBank, Techcombank
SEPAY_BANK_NAME=BIDV

# Tên hiển thị trên QR code (tên tài khoản ảo đã đăng ký)
# VD: "CONG TY ABC" hoặc "NGUYEN VAN A"
# Đây là tên người nhận tiền hiển thị khi quét QR
ACCOUNT_NAME="NGUYEN VAN A"